# ─── Anthropic ───────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Wallet ──────────────────────────────────────────────────
# NEVER commit your real private key. Use a dedicated trading wallet.
WALLET_PRIVATE_KEY=0x...

# ─── Chain ───────────────────────────────────────────────────
# Use Base Sepolia for testing, Base Mainnet for production
RPC_URL=https://sepolia.base.org
CHAIN=base-sepolia

# ─── Agent Config ────────────────────────────────────────────
# How often the agent checks markets (milliseconds)
POLL_INTERVAL_MS=60000

# Max % of portfolio to risk per trade (e.g. 0.02 = 2%)
MAX_RISK_PER_TRADE=0.02

# Stop-loss threshold % (e.g. 0.05 = 5% drop triggers stop-loss)
STOP_LOSS_THRESHOLD=0.05

# ─── Synthesis Hackathon ─────────────────────────────────────
SYNTHESIS_API_KEY=sk-synth-...
SYNTHESIS_PARTICIPANT_ID=07e031118427415c896b7247b466b905
